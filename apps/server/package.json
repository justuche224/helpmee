{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.3.7",
    "@better-auth/expo": "^1.3.7",
    "@orpc/client": "^1.8.6",
    "@orpc/openapi": "^1.8.6",
    "@orpc/server": "^1.8.6",
    "@orpc/zod": "^1.8.6",
    "@react-email/components": "^0.5.2",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.3.7",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.2",
    "nodemailer": "^7.0.6",
    "pg": "^8.14.1",
    "postgres": "^3.4.7",
    "uploadthing": "^7.7.4",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.6",
    "@types/nodemailer": "^7.0.1",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.2",
    "tsdown": "^0.14.1",
    "typescript": "^5.8.2"
  }
}
